# Base template for WEBSITE/.env
# Copy the local or production example that matches your target runtime.
# Do not commit WEBSITE/.env or any file that contains secrets or private values.

# Pre-launch local development currently uses the real development database `arivena`.
# After production launch, create a separate local/dev database and never use production
# player data for destructive tests, resets, fixtures, or migration experiments.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arivena
DB_USER=root
DB_PASS=

# Frontend API
# Local dev should use `api` so Vite proxies /api to the repo-root PHP runtime.
# Production should use the real published API URL instead.
VITE_API_BASE_URL=api
VITE_USE_MOCK=false
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# Runtime environment
APP_ENV=local
UCP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
UCP_LOCAL_MAIL_MODE=preview
# Local OTP preview is allowed only when BOTH are true:
# - APP_ENV=local
# - UCP_LOCAL_MAIL_MODE=preview
# Optional local-preview-only resend cooldown override for smoke tests.
# Keep blank or omit outside authorized local preview testing.
UCP_LOCAL_OTP_RESEND_COOLDOWN_SECONDS=
# Production must never use preview mode.

# Local dev commands:
# - PHP API from repo root: php -S 127.0.0.1:8000 -t WEBSITE/public
# - Frontend from WEBSITE: npm run dev -- --host 0.0.0.0 --port 3000

# Mail / secrets - use placeholders only in tracked example files
# Keep real SMTP values only in private WEBSITE/.env.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Pahlawan Roleplay
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Website Discord OAuth and guild automation. Keep all values server-side.
# Private WEBSITE/.env takes priority; ucp_system_settings remains a compatibility fallback.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_WARGA_ID=
DISCORD_REDIRECT_URI=http://127.0.0.1:8000/api/discord_callback.php

# Server-side Story Review AI local/production baseline.
# Traffic is intended to be enabled only when a valid private server-side key is configured.
# A blank or invalid key fails closed. Never rename provider credentials to VITE_* variables.
AI_ENABLED=true
AI_STORY_REVIEW_ENABLED=true
AI_PROVIDER=nvidia
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_STORY_REVIEW_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_NIM_API_KEY=
AI_ALLOWED_BASE_URLS=https://integrate.api.nvidia.com/v1
AI_ALLOWED_MODELS=deepseek-ai/deepseek-v4-flash
AI_STORY_REVIEW_MAX_INPUT_CHARS=50000
AI_STORY_REVIEW_MAX_OUTPUT_TOKENS=600
AI_STORY_REVIEW_TEMPERATURE=0
AI_CONNECT_TIMEOUT_MS=3000
AI_STORY_REVIEW_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_FALLBACK_ENABLED=false
# Reserved for the approved gateway rate-limit implementation.
AI_STORY_REVIEW_RATE_5M=3
AI_STORY_REVIEW_RATE_HOUR=12
AI_STORY_REVIEW_RATE_DAY=40
AI_STORY_REVIEW_GLOBAL_CONCURRENCY=2
AI_STORY_REVIEW_STORY_COOLDOWN_SECONDS=60
AI_STORY_REVIEW_STORY_RATE_HOUR=3
# Optional private server paths. Defaults use the OS temp directory and WEBSITE/.runtime-logs.
AI_RATE_LIMIT_STORAGE_DIR=
AI_STORY_REVIEW_LOG_PATH=
