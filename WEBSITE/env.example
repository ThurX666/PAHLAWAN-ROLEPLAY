# Base template for WEBSITE/.env
# Copy the local or production example that matches your target runtime,
# then fill in private values locally without committing secrets.

# Database - HARUS sama dengan GAMEMODE/gamemodes/utils/utils_defines.inc
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arivena
DB_USER=root
DB_PASS=

# Frontend API
# Local dev should generally use `api` so Vite can proxy /api to the PHP runtime.
# Production should use the real published API URL.
VITE_API_BASE_URL=api
VITE_USE_MOCK=false
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# Runtime environment
APP_ENV=local
UCP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UCP_LOCAL_MAIL_MODE=error
# Supported local mail modes:
# - error: fail clearly if SMTP/PHPMailer are missing
# - preview: expose OTP in local-only preview response/log
# - smtp: require real SMTP delivery

# Mail / secrets - leave blank in example files
SMTP_USER=
SMTP_PASS=
