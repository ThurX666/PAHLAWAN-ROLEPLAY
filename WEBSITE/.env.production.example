# Production template for WEBSITE/.env
# Copy to the deployment environment and fill in real values there.
# Do not commit deployed secret values back into the repository.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=arivena
DB_USER=
DB_PASS=

# This must be the production database only in the deployed production environment.
# Never point local destructive tests at production player data.

# Published frontend/API values
VITE_API_BASE_URL=https://your-domain.example/api
VITE_USE_MOCK=false

APP_ENV=production
UCP_ALLOWED_ORIGINS=https://your-domain.example

# Production must use real SMTP and real OTP email delivery.
# OTP preview must never be enabled in production.
UCP_LOCAL_MAIL_MODE=smtp
# Do not set UCP_LOCAL_OTP_RESEND_COOLDOWN_SECONDS in production or staging.
# Keep real SMTP values only in private deployment environment files.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Pahlawan Roleplay
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Website Discord OAuth and guild automation. Inject private values outside the repository.
# Register this exact callback URI in the Discord developer application.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_WARGA_ID=
DISCORD_REDIRECT_URI=https://your-domain.example/api/discord_callback.php

# Approved production baseline: enabled when a valid server-side key is injected.
# A blank or invalid key fails closed without persisting a partial AI review.
# Inject NVIDIA_NIM_API_KEY outside the repository. Never expose it through VITE_ variables.
AI_ENABLED=true
AI_STORY_REVIEW_ENABLED=true
AI_PROVIDER=nvidia
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_STORY_REVIEW_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_NIM_API_KEY=
AI_ALLOWED_BASE_URLS=https://integrate.api.nvidia.com/v1
AI_ALLOWED_MODELS=deepseek-ai/deepseek-v4-flash
AI_STORY_REVIEW_MAX_INPUT_CHARS=50000
AI_STORY_REVIEW_MAX_OUTPUT_TOKENS=600
AI_STORY_REVIEW_TEMPERATURE=0
AI_CONNECT_TIMEOUT_MS=3000
AI_STORY_REVIEW_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_FALLBACK_ENABLED=false
AI_STORY_REVIEW_RATE_5M=3
AI_STORY_REVIEW_RATE_HOUR=12
AI_STORY_REVIEW_RATE_DAY=40
AI_STORY_REVIEW_GLOBAL_CONCURRENCY=2
AI_STORY_REVIEW_STORY_COOLDOWN_SECONDS=60
AI_STORY_REVIEW_STORY_RATE_HOUR=3
AI_RATE_LIMIT_STORAGE_DIR=
AI_STORY_REVIEW_LOG_PATH=

UCP_AUTO_MIGRATE=false
SAMP_SERVER_IP=127.0.0.1
SAMP_SERVER_PORT=7777
