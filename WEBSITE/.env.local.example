# Local development template for WEBSITE/.env
# Copy to WEBSITE/.env on your local machine and fill in only local/private values.
# Do not commit WEBSITE/.env or any file containing secrets, OTPs, cookies, or credentials.

# Database - must match the local game/server database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arivena
DB_USER=root
DB_PASS=

# Frontend dev uses the Vite /api proxy to reach the repo-root PHP runtime
VITE_API_BASE_URL=api
VITE_USE_MOCK=false
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# Repo-root PHP runtime / browser origins
APP_ENV=local
UCP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Local OTP preview is allowed only for explicit local testing.
# Safe preview preconditions:
# - APP_ENV=local
# - UCP_LOCAL_MAIL_MODE=preview
# Any other environment or mode must not expose preview OTP output.
UCP_LOCAL_MAIL_MODE=preview

# Local dev commands
# 1. From repo root: php -S 127.0.0.1:8000 -t WEBSITE/public
# 2. From WEBSITE: npm run dev -- --host 0.0.0.0 --port 3000

# Leave blank unless you intentionally test real SMTP in local dev.
SMTP_USER=
SMTP_PASS=

# Story Review AI remains deterministic unless both flags are explicitly enabled.
# Provider credentials are server-side only. Never add a VITE_ prefix to AI secrets.
AI_ENABLED=false
AI_STORY_REVIEW_ENABLED=false
AI_PROVIDER=nvidia
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_STORY_REVIEW_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_NIM_API_KEY=
AI_ALLOWED_BASE_URLS=https://integrate.api.nvidia.com/v1
AI_ALLOWED_MODELS=deepseek-ai/deepseek-v4-flash
AI_STORY_REVIEW_MAX_INPUT_CHARS=50000
AI_STORY_REVIEW_MAX_OUTPUT_TOKENS=600
AI_STORY_REVIEW_TEMPERATURE=0
AI_CONNECT_TIMEOUT_MS=3000
AI_STORY_REVIEW_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_FALLBACK_ENABLED=false
AI_STORY_REVIEW_RATE_5M=3
AI_STORY_REVIEW_RATE_HOUR=12
AI_STORY_REVIEW_RATE_DAY=40
AI_STORY_REVIEW_GLOBAL_CONCURRENCY=2
AI_STORY_REVIEW_STORY_COOLDOWN_SECONDS=60
AI_STORY_REVIEW_STORY_RATE_HOUR=3
AI_RATE_LIMIT_STORAGE_DIR=
AI_STORY_REVIEW_LOG_PATH=

UCP_AUTO_MIGRATE=false
SAMP_SERVER_IP=127.0.0.1
SAMP_SERVER_PORT=7777
