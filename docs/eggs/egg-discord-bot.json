{
  "_comment": "Pterodactyl Egg - Discord Bot PAHLAWAN ROLEPLAY (Node.js 20). Untuk PHRP-AI module dan command handler.",
  "meta": {
    "version": "1.0.0",
    "update_url": null
  },
  "exported_at": "2026-06-27",
  "name": "Discord Bot",
  "author": "support@pahlawan-roleplay.local",
  "description": "Custom egg untuk Discord bot PAHLAWAN ROLEPLAY. Node.js 20 LTS, Discord.js v14, dengan shared MySQL untuk PHRP-AI module dan persistent state.",
  "features": [
    "eula",
    "pid_limit"
  ],
  "docker_images": {
    "Node 20 Alpine": "node:20-alpine"
  },
  "file_denylist": [],
  "startup": "node index.js",
  "config": {
    "files": "{}",
    "startup": "{\"value\": \"node index.js\", \"userEditable\": false, \"rules\": [\"file\", \"executable\"]}",
    "logs": "{}",
    "stop": "stop"
  },
  "scripts": {
    "installation": {
      "script": "#!/bin/bash\n# Discord Bot install script\nset -e\n\ncd /mnt/server\n\nif [ ! -f package.json ]; then\n    echo \"[install] FAIL: package.json tidak ditemukan.\"\n    exit 1\nfi\n\necho \"[install] Installing npm dependencies (production)...\"\nnpm install --omit=dev --no-audit --no-fund\n\necho \"[install] Discord bot ready.\"\n",
      "container": "node:20-alpine",
      "entrypoint": "bash"
    }
  },
  "variables": [
    {
      "name": "Bot Prefix",
      "env_variable": "BOT_PREFIX",
      "default_value": "!",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:5",
      "field_type": "text"
    },
    {
      "name": "Bot Status",
      "env_variable": "BOT_STATUS",
      "default_value": "PAHLAWAN ROLEPLAY | Pre-Alpha",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:128",
      "field_type": "text"
    },
    {
      "name": "Discord Token",
      "env_variable": "DISCORD_TOKEN",
      "default_value": "",
      "user_viewable": false,
      "user_editable": true,
      "rules": "required|string|min:50",
      "field_type": "text"
    },
    {
      "name": "Discord Client ID",
      "env_variable": "DISCORD_CLIENT_ID",
      "default_value": "",
      "user_viewable": false,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "text"
    },
    {
      "name": "Discord Guild ID (test)",
      "env_variable": "DISCORD_GUILD_ID",
      "default_value": "",
      "user_viewable": false,
      "user_editable": true,
      "rules": "nullable|string",
      "field_type": "text"
    },
    {
      "name": "MySQL Host",
      "env_variable": "DB_HOST",
      "default_value": "172.17.0.1",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "text"
    },
    {
      "name": "MySQL Port",
      "env_variable": "DB_PORT",
      "default_value": "3306",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer",
      "field_type": "text"
    },
    {
      "name": "MySQL Database",
      "env_variable": "DB_NAME",
      "default_value": "pahlawan",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "text"
    },
    {
      "name": "MySQL User",
      "env_variable": "DB_USER",
      "default_value": "pahlawan_app",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "text"
    },
    {
      "name": "MySQL Password",
      "env_variable": "DB_PASSWORD",
      "default_value": "",
      "user_viewable": false,
      "user_editable": true,
      "rules": "required|string|min:1",
      "field_type": "text"
    },
    {
      "name": "Log Level",
      "env_variable": "LOG_LEVEL",
      "default_value": "info",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|in:debug,info,warn,error",
      "field_type": "text"
    }
  ]
}